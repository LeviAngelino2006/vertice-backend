generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENTE
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  nombre       String
  role         Role     @default(CLIENTE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

enum EstadoOrden {
  PAGADA
  CANCELADA
}

model Order {
  id            String      @id @default(uuid())
  numeroOrden   String      @unique
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  emailInvitado String?
  nombreEnvio   String
  direccion     String
  ciudad        String
  codigoPostal  String
  provincia     String
  telefono      String
  subtotal      Decimal
  total         Decimal
  estado        EstadoOrden @default(PAGADA)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id             String  @id @default(uuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String
  nombreProducto String
  talle          String
  color          String
  cantidad       Int
  precioUnitario Decimal
}

model Product {
  id             String   @id @default(uuid())
  nombre         String
  categoria      String
  precio         Decimal
  precioAnterior Decimal?
  colores        String[]
  talles         String[]
  imagenes       String[]
  descripcion    String
  destacado      Boolean  @default(false)
  nuevo          Boolean  @default(false)
  stock          Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
